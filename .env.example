# Repository-level local development template
# Copy required keys into service-level `.env` files under `services/*/.env`.
# Do NOT commit real secrets.

# Shared internal auth secret across account/game/ds-manager internal APIs.
QQT_INTERNAL_AUTH_SHARED_SECRET=replace_me_internal_auth_shared_secret

# Shared battle ticket signing secret across account_service and battle DS.
QQT_BATTLE_TICKET_SHARED_SECRET=replace_me_battle_ticket_shared_secret

