DSM_HTTP_ADDR=127.0.0.1:18090

# Internal auth for DSM control plane
DSM_INTERNAL_AUTH_KEY_ID=primary
DSM_INTERNAL_AUTH_SHARED_SECRET=replace_me_internal_auth_shared_secret
DSM_INTERNAL_AUTH_MAX_SKEW_SECONDS=60

# Godot battle DS process launch
DSM_GODOT_EXECUTABLE=external/godot_binary/Godot_console.exe
DSM_PROJECT_ROOT=
DSM_BATTLE_SCENE_PATH=res://scenes/network/dedicated_server_scene.tscn
DSM_BATTLE_TICKET_SECRET=replace_me_battle_ticket_shared_secret
DSM_BATTLE_LOG_DIR=

# DS allocation / reaper
DSM_DS_HOST=127.0.0.1
DSM_PORT_RANGE_START=19010
DSM_PORT_RANGE_END=19050
DSM_READY_TIMEOUT_SEC=15
DSM_IDLE_REAP_TIMEOUT_SEC=300
