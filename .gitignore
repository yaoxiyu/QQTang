# Godot editor/import/runtime cache
.godot/
.import/
export.cfg
export_presets.cfg

# Godot local user data / logs
Godot/
godot_binary/
app_userdata/
logs/
*.log
*.tmp

# IDE / local tool config
.vscode/
.claude/

# Test runtime artifacts
tests/**/reports/*
!tests/**/reports/.gitkeep
!tests/**/reports/raw/.gitkeep
tests/cli/appdata/

# Content CSV import noise
content_source/csv/**/*.translation
content_source/csv/**/*.csv.import

# Service env files (contain secrets)
.env
.env.*
**/.env
**/.env.*
!**/.env.example
services/*/.env
services/*/.env.local
services/*/.env.development
services/*/.env.test
services/*/.env.prod

# Local secrets / credentials
secrets/
**/secrets/
*.secret
*.secrets
*.key
*.pem
*.p12
*.pfx

# Local runtime / packaging artifacts
build/
dist/
out/
/release/
artifacts/
exports/
*.pck
*.zip
*.7z
*.tar
*.tar.gz
*.tgz
*.apk
*.ipa
*.x86_64
*.exe

# Native extension local build artifacts
addons/qqt_native/.sconsign.dblite
addons/qqt_native/bin/
addons/qqt_native/src/**/*.obj
addons/qqt_native/src/**/*.obj.import

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Phase26 release hygiene (explicit guards)
tests/reports/raw/
tests/reports/tmp/

# Additional IDE / editor local noise
.idea/
*.suo
*.user
*.userossc
*.sln.docstates

# C# build outputs in test projects
tests/csharp/**/bin/
tests/csharp/**/obj/

# Local service runtime data/cache
services/**/data/
services/**/cache/
services/**/tmp/

# Generated C# proto metadata (recreated by Godot import, non-source-of-truth)
network/client_net/generated/*.uid
