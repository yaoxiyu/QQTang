[configuration]
entry_symbol = "qqt_native_library_init"
compatibility_minimum = "4.6"

[libraries]
windows.editor.x86_64 = "res://addons/qqt_native/bin/qqt_native.windows.template_debug.x86_64.dll"
windows.template_debug.x86_64 = "res://addons/qqt_native/bin/qqt_native.windows.template_debug.x86_64.dll"
windows.template_release.x86_64 = "res://addons/qqt_native/bin/qqt_native.windows.template_release.x86_64.dll"
linux.editor.x86_64 = "res://addons/qqt_native/bin/libqqt_native.linux.editor.x86_64.so"
linux.template_debug.x86_64 = "res://addons/qqt_native/bin/libqqt_native.linux.template_debug.x86_64.so"
linux.template_release.x86_64 = "res://addons/qqt_native/bin/libqqt_native.linux.template_release.x86_64.so"
macos.editor = "res://addons/qqt_native/bin/libqqt_native.macos.editor.framework"
macos.template_debug = "res://addons/qqt_native/bin/libqqt_native.macos.template_debug.framework"
macos.template_release = "res://addons/qqt_native/bin/libqqt_native.macos.template_release.framework"
